Task 1: Install Kafka and ZooKeeper
Step 1.1: Install Java
Kafka requires Java 8 or higher.

# Update package manager
sudo apt update

# Install OpenJDK 11
sudo apt install -y openjdk-11-jdk

# Verify installation
java -version
Step 1.2: Download and Extract Kafka
# Navigate to opt directory
cd /opt

# Download Kafka (version 3.6.0)
sudo wget https://downloads.apache.org/kafka/3.6.0/kafka_2.13-3.6.0.tgz

# Extract the archive
sudo tar -xzf kafka_2.13-3.6.0.tgz

# Create symbolic link for easier access
sudo ln -s kafka_2.13-3.6.0 kafka

# Set ownership
sudo chown -R $USER:$USER /opt/kafka_2.13-3.6.0
Step 1.3: Set Environment Variables
# Add Kafka to PATH
echo 'export KAFKA_HOME=/opt/kafka' >> ~/.bashrc
echo 'export PATH=$PATH:$KAFKA_HOME/bin' >> ~/.bashrc

# Reload bashrc
source ~/.bashrc

# Verify
echo $KAFKA_HOME
Task 2: Configure Multi-Broker Cluster
Step 2.1: Configure ZooKeeper
# Navigate to Kafka config directory
cd $KAFKA_HOME/config

# Create data directory for ZooKeeper
sudo mkdir -p /var/lib/zookeeper
sudo chown $USER:$USER /var/lib/zookeeper

# Edit ZooKeeper configuration
cat > zookeeper.properties << 'EOF'
dataDir=/var/lib/zookeeper
clientPort=2181
maxClientCnxns=0
admin.enableServer=false
tickTime=2000
initLimit=10
syncLimit=5
EOF
Step 2.2: Configure Broker 1
# Create log directories
sudo mkdir -p /var/lib/kafka-logs-1
sudo chown $USER:$USER /var/lib/kafka-logs-1

# Create broker 1 configuration
cat > server-1.properties << 'EOF'
broker.id=1
listeners=PLAINTEXT://localhost:9092
log.dirs=/var/lib/kafka-logs-1
zookeeper.connect=localhost:2181
num.network.threads=3
num.io.threads=8
socket.send.buffer.bytes=102400
socket.receive.buffer.bytes=102400
socket.request.max.bytes=104857600
num.partitions=3
num.recovery.threads.per.data.dir=1
offsets.topic.replication.factor=2
transaction.state.log.replication.factor=2
transaction.state.log.min.isr=2
log.retention.hours=168
log.segment.bytes=1073741824
log.retention.check.interval.ms=300000
zookeeper.connection.timeout.ms=18000
group.initial.rebalance.delay.ms=0
EOF
